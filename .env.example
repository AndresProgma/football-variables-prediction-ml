# Copia a .env y ajusta para producción.
PORT=8000

# CORS: lista separada por comas, o "*" para dev.
# Producción: usa tu dominio, ej: https://predictor.tudominio.com
ALLOWED_ORIGINS=*

# DB. Por defecto SQLite local. Para Postgres usa:
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./futbol.db
